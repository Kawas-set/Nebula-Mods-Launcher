<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="ModLauncher.Views.MainWindow"
    Title="{Binding Loc.WindowTitle}"
    Icon="/Assets/nebula-mods-launcher.ico"
    Width="1380"
    Height="900"
    MinWidth="880"
    MinHeight="560"
    SystemDecorations="None"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="48"
    TransparencyLevelHint="Transparent"
    CanResize="True"
    UseLayoutRounding="True"
    Background="Transparent">

  <Window.Resources>
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#090B19" Offset="0"/>
      <GradientStop Color="#0A0F21" Offset="0.36"/>
      <GradientStop Color="#07182B" Offset="0.68"/>
      <GradientStop Color="#07111D" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#11172A" Offset="0"/>
      <GradientStop Color="#161A38" Offset="0.34"/>
      <GradientStop Color="#10263D" Offset="0.72"/>
      <GradientStop Color="#0C1323" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#9F6BFF" Offset="0"/>
      <GradientStop Color="#5A7CFF" Offset="0.48"/>
      <GradientStop Color="#4CE2FF" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PanelBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#0B1221" Offset="0"/>
      <GradientStop Color="#0F172B" Offset="0.58"/>
      <GradientStop Color="#0A1322" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PanelAltBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#10192D" Offset="0"/>
      <GradientStop Color="#13203A" Offset="0.62"/>
      <GradientStop Color="#0E1730" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="MetricBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#111B32" Offset="0"/>
      <GradientStop Color="#0E1A2E" Offset="0.55"/>
      <GradientStop Color="#10213A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="InfoChipBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#171A38" Offset="0"/>
      <GradientStop Color="#132B45" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="StatusBannerBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#111B31" Offset="0"/>
      <GradientStop Color="#15213D" Offset="0.6"/>
      <GradientStop Color="#11223A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#17233A" Offset="0"/>
      <GradientStop Color="#19304A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SubtleButtonBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#271A4A" Offset="0"/>
      <GradientStop Color="#17344A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DangerButtonBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#3D2034" Offset="0"/>
      <GradientStop Color="#58364C" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="HeroTitleBrush" StartPoint="0,0" EndPoint="1,0">
      <GradientStop Color="#F7FBFF" Offset="0"/>
      <GradientStop Color="#A98FFF" Offset="0.42"/>
      <GradientStop Color="#62E1FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NebulaRibbonBrush" StartPoint="0,0.5" EndPoint="1,0.5">
      <GradientStop Color="#0066C7FF" Offset="0"/>
      <GradientStop Color="#2A79D4FF" Offset="0.22"/>
      <GradientStop Color="#226767FF" Offset="0.58"/>
      <GradientStop Color="#0024D7FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NebulaRibbonAltBrush" StartPoint="0,0.5" EndPoint="1,0.5">
      <GradientStop Color="#00AE5CFF" Offset="0"/>
      <GradientStop Color="#1D815EFF" Offset="0.18"/>
      <GradientStop Color="#2357C9FF" Offset="0.55"/>
      <GradientStop Color="#009A6BFF" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="PanelLineBrush" Color="#314E7C"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#63DFFF"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#221B46"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#76F0C6"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FF8DA9"/>
    <SolidColorBrush x:Key="DangerSoftBrush" Color="#341B2B"/>
    <SolidColorBrush x:Key="StarBrush" Color="#DFF7FF"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F7FBFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#D1DAF2"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8B95BA"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="Border.glass-panel">
      <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource PanelLineBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="26"/>
      <Setter Property="BoxShadow" Value="0 18 44 0 #24040A18"/>
    </Style>

    <Style Selector="Border.window-shell">
      <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="#3D5C90"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="32"/>
      <Setter Property="BoxShadow" Value="0 28 70 0 #30020A18"/>
    </Style>

    <Style Selector="Border.hero-card">
      <Setter Property="Background" Value="{StaticResource HeroBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="#4B69A4"/>
    </Style>

    <Style Selector="Border.sub-panel">
      <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
      <Setter Property="BorderBrush" Value="#2C416C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="BoxShadow" Value="0 12 28 0 #18040A18"/>
    </Style>

    <Style Selector="Border.metric-card">
      <Setter Property="Background" Value="{StaticResource MetricBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="#34527E"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="BoxShadow" Value="0 10 24 0 #14040A16"/>
    </Style>

    <Style Selector="Border.info-chip">
      <Setter Property="Background" Value="{StaticResource InfoChipBrush}"/>
      <Setter Property="BorderBrush" Value="#4265A0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="14,10"/>
    </Style>

    <Style Selector="Border.status-pill">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="999"/>
      <Setter Property="Padding" Value="12,7"/>
    </Style>

    <Style Selector="Border.status-pill.entry-status-pill">
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="Padding" Value="12,5"/>
      <Setter Property="Margin" Value="-8,-4,0,0"/>
    </Style>

    <Style Selector="TextBlock.status-pill-text">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="LineHeight" Value="16"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.status-banner">
      <Setter Property="Background" Value="{StaticResource StatusBannerBrush}"/>
      <Setter Property="BorderBrush" Value="#476AB0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="Padding" Value="18"/>
    </Style>

    <Style Selector="Border.titlebar-panel">
      <Setter Property="Background" Value="#0C1223"/>
      <Setter Property="BorderBrush" Value="#314A77"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="22"/>
      <Setter Property="BoxShadow" Value="0 12 28 0 #16030B18"/>
    </Style>

    <Style Selector="TextBlock.page-kicker">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#9AB6FF"/>
    </Style>

    <Style Selector="TextBlock.page-title">
      <Setter Property="FontSize" Value="46"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontFamily" Value="Bahnschrift"/>
      <Setter Property="Foreground" Value="{StaticResource HeroTitleBrush}"/>
    </Style>

    <Style Selector="TextBlock.page-subtitle">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.panel-title">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.panel-caption">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style Selector="TextBlock.field-value">
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.metric-number">
      <Setter Property="FontSize" Value="19"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="FontFamily" Value="Bahnschrift"/>
      <Setter Property="LineHeight" Value="20"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="TextBlock.meta-copy">
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.code-copy">
      <Setter Property="Foreground" Value="#E3EAFF"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontFamily" Value="Consolas"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.mod-title">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style Selector="Button">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
      <Setter Property="BorderBrush" Value="#4668A8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="18,12"/>
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="MinHeight" Value="50"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Button TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="FontSize" Value="16"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="LineHeight" Value="24"/>
    </Style>

    <Style Selector="Button:pointerover">
      <Setter Property="BorderBrush" Value="#79A0FF"/>
      <Setter Property="Background" Value="#203251"/>
      <Setter Property="RenderTransform" Value="scale(1.012)"/>
    </Style>

    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#15253D"/>
      <Setter Property="BorderBrush" Value="#5C83C8"/>
      <Setter Property="RenderTransform" Value="scale(0.988)"/>
    </Style>

    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.58"/>
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}"/>
      <Setter Property="BorderBrush" Value="#C6A8FF"/>
      <Setter Property="Foreground" Value="#08101F"/>
    </Style>

    <Style Selector="Button.primary TextBlock">
      <Setter Property="Foreground" Value="#09121C"/>
      <Setter Property="FontWeight" Value="Black"/>
    </Style>

    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="#7FEAFF"/>
      <Setter Property="BorderBrush" Value="#E0C5FF"/>
      <Setter Property="RenderTransform" Value="scale(1.016)"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="MinHeight" Value="84"/>
      <Setter Property="Padding" Value="20,18"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.action-button TextBlock">
      <Setter Property="FontFamily" Value="Bahnschrift"/>
      <Setter Property="FontSize" Value="17"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="LineHeight" Value="26"/>
    </Style>

    <Style Selector="Border.setting-panel">
      <Setter Property="MinWidth" Value="220"/>
      <Setter Property="Width" Value="230"/>
    </Style>

    <Style Selector="Button.subtle">
      <Setter Property="Background" Value="{StaticResource SubtleButtonBrush}"/>
      <Setter Property="BorderBrush" Value="#7A6DDB"/>
    </Style>

    <Style Selector="Button.subtle TextBlock">
      <Setter Property="Foreground" Value="#F5EEFF"/>
    </Style>

    <Style Selector="Button.danger">
      <Setter Property="Background" Value="{StaticResource DangerButtonBrush}"/>
      <Setter Property="BorderBrush" Value="#B16288"/>
      <Setter Property="Foreground" Value="#FFE2EC"/>
    </Style>

    <Style Selector="Button.danger TextBlock">
      <Setter Property="Foreground" Value="#FFE7F0"/>
    </Style>

    <Style Selector="Button.title-button">
      <Setter Property="Width" Value="42"/>
      <Setter Property="Height" Value="38"/>
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Background" Value="#141A2E"/>
      <Setter Property="BorderBrush" Value="#3E5380"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="Button.title-button.close">
      <Setter Property="Background" Value="#311729"/>
      <Setter Property="BorderBrush" Value="#8E4A6D"/>
      <Setter Property="Foreground" Value="#FFE7F0"/>
    </Style>

    <Style Selector="Button.title-button:pointerover">
      <Setter Property="Background" Value="#1B2440"/>
      <Setter Property="BorderBrush" Value="#6B8FD3"/>
      <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>

    <Style Selector="Button.title-button.close:pointerover">
      <Setter Property="Background" Value="#45203A"/>
      <Setter Property="BorderBrush" Value="#D5759E"/>
    </Style>

    <Style Selector="Button.titlebar-pill">
      <Setter Property="Background" Value="#151D34"/>
      <Setter Property="BorderBrush" Value="#576D9F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="16,0"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="MinWidth" Value="96"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.titlebar-pill TextBlock">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="LineHeight" Value="18"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Button.titlebar-pill.quiet">
      <Setter Property="Background" Value="#11182A"/>
      <Setter Property="BorderBrush" Value="#44567F"/>
      <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <Style Selector="Button.titlebar-pill:pointerover">
      <Setter Property="Background" Value="#1A2742"/>
      <Setter Property="BorderBrush" Value="#7B94D2"/>
      <Setter Property="RenderTransform" Value="scale(1.016)"/>
    </Style>

    <Style Selector="Button.titlebar-pill.quiet:pointerover">
      <Setter Property="Background" Value="#182238"/>
      <Setter Property="BorderBrush" Value="#7689B9"/>
    </Style>

    <Style Selector="ComboBox.panel-input">
      <Setter Property="Background" Value="#0B1323"/>
      <Setter Property="BorderBrush" Value="#3F5E97"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CornerRadius" Value="15"/>
      <Setter Property="MinHeight" Value="48"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ComboBox.panel-input:pointerover">
      <Setter Property="Background" Value="#10192E"/>
      <Setter Property="BorderBrush" Value="#6788D4"/>
      <Setter Property="RenderTransform" Value="scale(1.006)"/>
    </Style>

    <Style Selector="ComboBox.panel-input:focus">
      <Setter Property="Background" Value="#101C30"/>
      <Setter Property="BorderBrush" Value="#88E7FF"/>
    </Style>

    <Style Selector="ComboBox.titlebar-input">
      <Setter Property="Background" Value="#10182B"/>
      <Setter Property="BorderBrush" Value="#496085"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="MinWidth" Value="112"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="ComboBox.titlebar-input:pointerover">
      <Setter Property="Background" Value="#16233A"/>
      <Setter Property="BorderBrush" Value="#7E97C9"/>
      <Setter Property="RenderTransform" Value="scale(1.012)"/>
    </Style>

    <Style Selector="TextBox.panel-input">
      <Setter Property="Background" Value="#0B1323"/>
      <Setter Property="BorderBrush" Value="#3F5E97"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CornerRadius" Value="15"/>
      <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
      <Setter Property="RenderTransform" Value="scale(1)"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBox.panel-input:pointerover">
      <Setter Property="Background" Value="#10182B"/>
      <Setter Property="BorderBrush" Value="#6788D4"/>
      <Setter Property="RenderTransform" Value="scale(1.004)"/>
    </Style>

    <Style Selector="TextBox.panel-input:focus">
      <Setter Property="Background" Value="#101B30"/>
      <Setter Property="BorderBrush" Value="#88E7FF"/>
    </Style>

    <Style Selector="TextBox.readonly-panel">
      <Setter Property="Background" Value="#0B1222"/>
      <Setter Property="BorderBrush" Value="#39588D"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
      <Setter Property="Padding" Value="14,12"/>
      <Setter Property="CornerRadius" Value="18"/>
      <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style Selector="ListBox.catalog-list">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0,2,0,8"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="FocusAdorner" Value="{x:Null}"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Grid>
            <Border Name="ItemHost"
                    Background="Transparent"
                    CornerRadius="30"
                    ClipToBounds="True"
                    Padding="2">
              <ContentPresenter Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:pointerover">
      <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:pointerover Border.catalog-card">
      <Setter Property="Background" Value="#162642"/>
      <Setter Property="BorderBrush" Value="#6986D4"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="BoxShadow" Value="0 18 36 0 #16071224"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:selected Border.catalog-card">
      <Setter Property="Background" Value="#223962"/>
      <Setter Property="BorderBrush" Value="#63DFFF"/>
      <Setter Property="BorderThickness" Value="3"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="BoxShadow" Value="0 0 0 1 #2896CFF0, 0 24 48 0 #16081428"/>
    </Style>

    <Style Selector="ListBox.catalog-list Border#SelectedMarker">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Opacity" Value="0"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:selected Border#SelectedMarker">
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:selected TextBlock.mod-title">
      <Setter Property="Foreground" Value="#F7FBFF"/>
    </Style>

    <Style Selector="ListBox.catalog-list ListBoxItem:selected TextBlock.meta-copy">
      <Setter Property="Foreground" Value="#E2EBFF"/>
    </Style>

    <Style Selector="Border.catalog-card">
      <Setter Property="Background" Value="{StaticResource PanelAltBrush}"/>
      <Setter Property="BorderBrush" Value="#2C416C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="24"/>
      <Setter Property="ClipToBounds" Value="True"/>
      <Setter Property="BoxShadow" Value="0 12 24 0 #16030B18"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
        </Transitions>
      </Setter>
    </Style>
  </Window.Styles>

  <Border x:Name="WindowShell" Classes="window-shell" Margin="10" ClipToBounds="True">
    <Grid ClipToBounds="True">
      <Canvas IsHitTestVisible="False">
        <Border Width="500" Height="500" CornerRadius="250" Background="#5726A9" Opacity="0.16" Canvas.Left="-140" Canvas.Top="-130"/>
        <Border Width="620" Height="620" CornerRadius="310" Background="#2F6CFF" Opacity="0.08" Canvas.Left="700" Canvas.Top="-200"/>
        <Border Width="460" Height="460" CornerRadius="230" Background="#24D0FF" Opacity="0.07" Canvas.Left="980" Canvas.Top="430"/>
        <Border Width="320" Height="320" CornerRadius="160" Background="#FF5ACD" Opacity="0.05" Canvas.Left="520" Canvas.Top="90"/>
        <Border Width="820" Height="170" CornerRadius="85" Background="{StaticResource NebulaRibbonBrush}" Opacity="0.09" Canvas.Left="250" Canvas.Top="555"/>
        <Border Width="540" Height="140" CornerRadius="70" Background="{StaticResource NebulaRibbonAltBrush}" Opacity="0.08" Canvas.Left="1010" Canvas.Top="112"/>
        <Border Width="250" Height="250" CornerRadius="125" Background="#815FFF" Opacity="0.06" Canvas.Left="1120" Canvas.Top="48"/>
        <Border Width="180" Height="180" CornerRadius="90" Background="#54E4FF" Opacity="0.06" Canvas.Left="178" Canvas.Top="602"/>
        <Border Width="4" Height="4" CornerRadius="2" Background="{StaticResource StarBrush}" Opacity="0.42" Canvas.Left="228" Canvas.Top="96"/>
        <Border Width="3" Height="3" CornerRadius="1.5" Background="{StaticResource StarBrush}" Opacity="0.28" Canvas.Left="412" Canvas.Top="162"/>
        <Border Width="5" Height="5" CornerRadius="2.5" Background="{StaticResource StarBrush}" Opacity="0.26" Canvas.Left="848" Canvas.Top="84"/>
        <Border Width="3" Height="3" CornerRadius="1.5" Background="{StaticResource StarBrush}" Opacity="0.34" Canvas.Left="1184" Canvas.Top="214"/>
        <Border Width="4" Height="4" CornerRadius="2" Background="{StaticResource StarBrush}" Opacity="0.24" Canvas.Left="1326" Canvas.Top="142"/>
        <Border Width="3" Height="3" CornerRadius="1.5" Background="{StaticResource StarBrush}" Opacity="0.3" Canvas.Left="1526" Canvas.Top="404"/>
        <Border Width="5" Height="5" CornerRadius="2.5" Background="{StaticResource StarBrush}" Opacity="0.2" Canvas.Left="1026" Canvas.Top="680"/>
        <Border Width="3" Height="3" CornerRadius="1.5" Background="{StaticResource StarBrush}" Opacity="0.38" Canvas.Left="624" Canvas.Top="754"/>
        <Border Width="4" Height="4" CornerRadius="2" Background="{StaticResource StarBrush}" Opacity="0.22" Canvas.Left="1448" Canvas.Top="614"/>
      </Canvas>

      <Grid x:Name="WindowContentGrid" Margin="18" RowDefinitions="Auto,12,*">
      <Border x:Name="TitleBarPanel" Classes="titlebar-panel"
              Padding="10,8"
              PointerPressed="TitleBarPointerPressed"
              DoubleTapped="TitleBarDoubleTapped">
        <Grid ColumnDefinitions="Auto,16,*,Auto,8,Auto,12,Auto">
          <Border Width="42"
                  Height="42"
                  CornerRadius="14"
                  Background="#171A38"
                  BorderBrush="#8C74FF"
                  BorderThickness="1"
                  ClipToBounds="True"
                  Padding="2">
            <Image Source="/Assets/nebula-mods-launcher.png"
                   Stretch="UniformToFill"/>
          </Border>

          <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding Loc.WindowTitle}" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Loc.HeroKicker}" Classes="panel-caption"/>
          </StackPanel>

          <ComboBox Grid.Column="3"
                    Classes="titlebar-input"
                    ItemsSource="{Binding Languages}"
                    SelectedItem="{Binding SelectedLanguage, Mode=OneWay}"
                    SelectionChanged="LanguageSelectionChanged"/>

          <Button Grid.Column="5"
                  Classes="titlebar-pill quiet"
                  Click="AboutClicked">
            <TextBlock Text="{Binding Loc.ButtonAbout}"/>
          </Button>

          <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="6">
            <Button Classes="title-button" Click="MinimizeWindowClicked">
              <Border Width="14"
                      Height="2"
                      CornerRadius="999"
                      Background="#D9F0FF"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </Button>
            <Button Classes="title-button" Click="ToggleMaximizeClicked">
              <Path Width="12"
                    Height="12"
                    Stretch="Uniform"
                    StrokeThickness="1.4"
                    Stroke="#D9F0FF"
                    Data="M 1.5 1.5 L 10.5 1.5 L 10.5 10.5 L 1.5 10.5 Z"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Button>
            <Button Classes="title-button close" Click="CloseWindowClicked">
              <Path Width="12"
                    Height="12"
                    Stretch="Uniform"
                    StrokeThickness="1.8"
                    Stroke="#FFE6E6"
                    Data="M 1.5 1.5 L 10.5 10.5 M 10.5 1.5 L 1.5 10.5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <ScrollViewer x:Name="RootScrollViewer"
                    Grid.Row="2"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,18,*,16,Auto" MinHeight="940">
      <Border Classes="glass-panel hero-card" Padding="20">
        <Grid ColumnDefinitions="*,22,290">
          <StackPanel Spacing="12">
            <TextBlock Classes="page-kicker" Text="{Binding Loc.HeroKicker}"/>
            <TextBlock Classes="page-title" Text="Nebula Mods"/>
            <Border Width="118" Height="4" Background="{StaticResource PrimaryButtonBrush}" CornerRadius="999" HorizontalAlignment="Left"/>

            <WrapPanel Margin="0,10,0,0" Orientation="Horizontal">
              <Border Classes="info-chip" Margin="0,0,10,10">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <TextBlock Classes="panel-caption"
                             Text="{Binding Loc.MetricCatalog}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"/>
                  <TextBlock Classes="metric-number" Text="{Binding Mods.Count}"/>
                </StackPanel>
              </Border>

              <Border Classes="info-chip" Margin="0,0,10,10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricPlatform}"/>
                  <TextBlock Text="{Binding SelectedDownloadTargetDisplay}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
              </Border>

              <Border Classes="info-chip" Margin="0,0,10,10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricMode}"/>
                  <TextBlock Text="{Binding SelectedAssetSelectionModeDisplay}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
              </Border>

              <Border Classes="info-chip" Margin="0,0,10,10">
                <StackPanel Spacing="2">
                  <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricLanguage}"/>
                  <TextBlock Text="{Binding SelectedLanguageDisplay}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
              </Border>
            </WrapPanel>
          </StackPanel>

          <Grid Grid.Column="2" RowDefinitions="Auto,14,Auto" ColumnDefinitions="*,14,*">
            <Border Grid.ColumnSpan="3" Classes="metric-card" Padding="16">
              <Grid ColumnDefinitions="*,12,Auto">
                  <StackPanel Spacing="6">
                    <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricSelectedMod}"/>
                    <TextBlock Text="{Binding SelectedModNameDisplay}"
                               FontSize="18"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               MaxHeight="78"/>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Right">
                    <TextBlock Classes="panel-caption"
                               Text="{Binding Loc.MetricStatus}"
                               HorizontalAlignment="Right"/>
                    <Border Classes="status-pill"
                            Background="{Binding SelectedMod.StatusBadgeBackground}"
                            BorderBrush="{Binding SelectedMod.StatusBadgeBorder}"
                            HorizontalAlignment="Right">
                      <TextBlock Classes="status-pill-text"
                                 Text="{Binding SelectedMod.StatusPillText}"
                                 Foreground="{Binding SelectedMod.StatusBadgeForeground}"/>
                    </Border>
                  </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="2" Classes="metric-card" Padding="16">
              <StackPanel Spacing="6">
                <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricGameFolder}"/>
                <TextBlock Text="{Binding GameFolderPathDisplay}"
                           TextWrapping="Wrap"
                           FontSize="15"
                           MaxHeight="76"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Classes="metric-card" Padding="16">
              <StackPanel Spacing="6">
                <TextBlock Classes="panel-caption" Text="{Binding Loc.MetricLatestVersion}"/>
                <TextBlock Text="{Binding SelectedMod.LatestVersion}" FontSize="18" FontWeight="Bold"/>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </Border>

        <Grid Grid.Row="2" ColumnDefinitions="0.95*,24,1.2*" MinHeight="650">
        <Border Grid.Column="0" Classes="glass-panel" Padding="18">
          <Grid RowDefinitions="Auto,12,Auto,14,*">
            <Grid ColumnDefinitions="*,14,Auto">
              <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" Text="{Binding Loc.CatalogTitle}"/>
                <TextBlock Classes="meta-copy" Text="{Binding Loc.CatalogCaption}"/>
              </StackPanel>

              <Border Grid.Column="2" Classes="info-chip" HorizontalAlignment="Right" VerticalAlignment="Top">
                <StackPanel Spacing="2" HorizontalAlignment="Center">
                  <TextBlock Classes="panel-caption"
                             Text="{Binding Loc.CatalogTotal}"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"/>
                  <TextBlock Classes="metric-number" Text="{Binding Mods.Count}"/>
                </StackPanel>
              </Border>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="8">
              <TextBlock Classes="panel-caption" Text="{Binding CatalogSearchLabel}"/>
              <TextBox Classes="panel-input"
                       Text="{Binding CatalogSearchText, Mode=TwoWay}"
                       Watermark="{Binding CatalogSearchWatermark}"/>
            </StackPanel>

            <ListBox Grid.Row="4"
                     Classes="catalog-list"
                     MinHeight="580"
                     ItemsSource="{Binding Mods}"
                     SelectedItem="{Binding SelectedMod}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border Classes="sub-panel catalog-card"
                          Padding="16"
                          Margin="1"
                          CornerRadius="24"
                          ClipToBounds="True">
                    <Grid>
                      <Border Name="SelectedMarker"
                              Width="54"
                              Height="6"
                              Margin="0,0,18,0"
                              CornerRadius="999"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"/>

                      <Grid ColumnDefinitions="60,14,*">
                      <Border Width="60"
                              Height="60"
                              CornerRadius="18"
                              Background="{Binding StatusBadgeBackground}"
                              BorderBrush="{Binding StatusBadgeBorder}"
                              BorderThickness="1"
                              ClipToBounds="True">
                        <Grid>
                          <Image Source="{Binding IconUri}"
                                 Stretch="UniformToFill"
                                 IsVisible="{Binding HasCustomIcon}"/>
                          <TextBlock Text="{Binding Monogram}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     Foreground="{Binding StatusBadgeForeground}"
                                     IsVisible="{Binding ShowMonogram}"/>
                        </Grid>
                      </Border>

                      <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Classes="mod-title" Text="{Binding Name}" TextWrapping="Wrap"/>
                        <TextBlock Classes="meta-copy" Text="{Binding Author}"/>
                        <TextBlock Classes="code-copy" Text="{Binding RepoDisplay}" TextTrimming="CharacterEllipsis"/>
                        <Border Classes="status-pill"
                                Background="{Binding StatusBadgeBackground}"
                                BorderBrush="{Binding StatusBadgeBorder}"
                                HorizontalAlignment="Left">
                          <TextBlock Classes="status-pill-text"
                                     Text="{Binding StatusText}"
                                     Foreground="{Binding StatusAccentBrush}"/>
                        </Border>
                      </StackPanel>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Grid Grid.Column="2" RowDefinitions="Auto,18,*">
          <Border Classes="glass-panel" Padding="18">
            <StackPanel Spacing="18">
              <StackPanel Spacing="14">
                <TextBlock Classes="panel-title" Text="{Binding Loc.ActionsTitle}"/>

                <Grid ColumnDefinitions="*,14,*"
                      RowDefinitions="Auto,14,Auto,14,Auto,14,Auto">
                  <Button Grid.Row="0" Grid.Column="0" Classes="action-button" Click="LoadClicked">
                    <TextBlock Text="{Binding Loc.ButtonLoadCatalog}" TextWrapping="Wrap"/>
                  </Button>
                  <Button Grid.Row="0" Grid.Column="2" Classes="action-button subtle" Click="RefreshClicked">
                    <TextBlock Text="{Binding Loc.ButtonCheckUpdates}" TextWrapping="Wrap"/>
                  </Button>

                  <Button Grid.Row="2" Grid.Column="0" Classes="action-button" Click="DownloadClicked">
                    <TextBlock Text="{Binding Loc.ButtonDownloadRelease}" TextWrapping="Wrap"/>
                  </Button>
                  <Button Grid.Row="2" Grid.Column="2" Classes="action-button primary" Click="InstallClicked">
                    <TextBlock Text="{Binding Loc.ButtonInstall}" TextWrapping="Wrap"/>
                  </Button>

                  <Button Grid.Row="4"
                          Grid.Column="0"
                          Classes="action-button danger"
                          Click="RemoveClicked"
                          IsEnabled="{Binding CanRemoveSelectedDll}">
                    <TextBlock Text="{Binding Loc.ButtonRemoveDll}" TextWrapping="Wrap"/>
                  </Button>
                  <Button Grid.Row="4" Grid.Column="2" Classes="action-button" Click="ChooseGameFolderClicked">
                    <TextBlock Text="{Binding Loc.ButtonChooseGameFolder}" TextWrapping="Wrap"/>
                  </Button>

                  <Button Grid.Row="6"
                          Grid.ColumnSpan="3"
                          Classes="action-button subtle"
                          Click="AutoDetectGameFolderClicked">
                    <TextBlock Text="{Binding AutoDetectGameFolderButtonText}" TextWrapping="Wrap"/>
                  </Button>
                </Grid>

                <Border Classes="status-banner">
                  <StackPanel Spacing="10">
                    <TextBlock Classes="panel-caption" Text="{Binding Loc.SessionTitle}"/>
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"/>
                    <ProgressBar Height="6"
                                 Foreground="{StaticResource AccentBrush}"
                                 IsIndeterminate="{Binding IsBusy}"
                                 IsVisible="{Binding IsBusy}"/>
                  </StackPanel>
                </Border>
              </StackPanel>

              <WrapPanel Orientation="Horizontal">
                <Border Classes="sub-panel setting-panel" Padding="16" Margin="0,0,14,14">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="panel-caption" Text="{Binding Loc.FieldDownloadTarget}"/>
                    <ComboBox Classes="panel-input"
                              ItemsSource="{Binding DownloadTargets}"
                              SelectedItem="{Binding SelectedDownloadTarget, Mode=OneWay}"
                              SelectionChanged="DownloadTargetSelectionChanged">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Border>

                <Border Classes="sub-panel setting-panel" Padding="16" Margin="0,0,14,14">
                  <StackPanel Spacing="8">
                    <TextBlock Classes="panel-caption" Text="{Binding Loc.FieldAssetMode}"/>
                    <ComboBox Classes="panel-input"
                              ItemsSource="{Binding AssetSelectionModes}"
                              SelectedItem="{Binding SelectedAssetSelectionMode, Mode=OneWay}"
                              SelectionChanged="AssetSelectionModeChanged">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Border>

              </WrapPanel>
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Classes="glass-panel">
            <ScrollViewer x:Name="DetailsScrollViewer" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Spacing="16" Margin="18">
                <Border Classes="sub-panel" Padding="18">
                  <Grid ColumnDefinitions="92,16,*">
                      <Border Width="92"
                             Height="92"
                             CornerRadius="26"
                             Background="{Binding SelectedMod.StatusBadgeBackground}"
                             BorderBrush="{Binding SelectedMod.StatusBadgeBorder}"
                             BorderThickness="1"
                            ClipToBounds="True">
                      <Grid>
                        <Image Source="{Binding SelectedMod.IconUri}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding SelectedMod.HasCustomIcon}"/>
                        <TextBlock Text="{Binding SelectedMod.Monogram}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{Binding SelectedMod.StatusBadgeForeground}"
                                   IsVisible="{Binding SelectedMod.ShowMonogram}"/>
                      </Grid>
                    </Border>

                      <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                        <Grid ColumnDefinitions="*,12,Auto">
                          <TextBlock Text="{Binding SelectedModNameDisplay}"
                                     FontSize="26"
                                     FontWeight="Bold"
                                     FontFamily="Bahnschrift"
                                     TextWrapping="Wrap"
                                     MaxHeight="96"
                                     VerticalAlignment="Top"/>

                          <Border Grid.Column="2"
                                  Classes="status-pill"
                                  Background="{Binding SelectedMod.StatusBadgeBackground}"
                                  BorderBrush="{Binding SelectedMod.StatusBadgeBorder}"
                                  VerticalAlignment="Top"
                                  Margin="0,4,0,0">
                            <TextBlock Classes="status-pill-text"
                                       Text="{Binding SelectedMod.StatusPillText}"
                                       Foreground="{Binding SelectedMod.StatusBadgeForeground}"/>
                          </Border>
                        </Grid>

                        <TextBlock Classes="meta-copy" Text="{Binding SelectedMod.Author}"/>
                        <TextBlock Classes="code-copy" Text="{Binding SelectedMod.RepoDisplay}"/>
                        <TextBlock Text="{Binding InstallModeDisplay}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                  </Grid>
                </Border>

                <Border Classes="sub-panel" Padding="18">
                  <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="110,*">
                      <TextBlock Classes="field-label"
                                 Text="{Binding Loc.FieldModBy}"
                                 VerticalAlignment="Top"/>
                      <TextBlock Grid.Column="1"
                                 Classes="field-value"
                                 Text="{Binding SelectedMod.Author}"
                                 FontSize="15"/>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                      <TextBlock Classes="field-label"
                                 Text="{Binding Loc.FieldSource}"
                                 VerticalAlignment="Top"/>
                      <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Classes="meta-copy" Text="{Binding Loc.FieldSourceCaption}"/>
                        <TextBlock Classes="code-copy"
                                   Text="{Binding SelectedMod.SourceUrl}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                      <TextBlock Classes="field-label"
                                 Text="{Binding Loc.FieldLicense}"
                                 VerticalAlignment="Top"/>
                      <TextBlock Grid.Column="1"
                                 Classes="field-value"
                                 Text="{Binding SelectedMod.LicenseDisplay}"
                                 FontSize="15"/>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                      <TextBlock Classes="field-label"
                                 Text="{Binding Loc.FieldEntryStatus}"
                                 VerticalAlignment="Top"/>
                      <Border Grid.Column="1"
                              Classes="status-pill entry-status-pill"
                              Background="{Binding SelectedMod.StatusBadgeBackground}"
                              BorderBrush="{Binding SelectedMod.StatusBadgeBorder}"
                              HorizontalAlignment="Left">
                        <TextBlock Classes="status-pill-text"
                                   Text="{Binding SelectedMod.EntryStatusDisplay}"
                                   Foreground="{Binding SelectedMod.StatusBadgeForeground}"/>
                      </Border>
                    </Grid>

                    <Button Classes="subtle"
                            HorizontalAlignment="Left"
                            Click="OpenSelectedSourceClicked">
                      <TextBlock Text="{Binding Loc.ButtonOpenSource}" TextWrapping="Wrap"/>
                    </Button>
                  </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,14,*"
                      RowDefinitions="Auto,14,Auto,14,Auto">
                  <Border Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldLatestVersion}"/>
                      <TextBlock Classes="field-value" Text="{Binding SelectedMod.LatestVersion}"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldInstalledVersion}"/>
                      <TextBlock Classes="field-value" Text="{Binding SelectedMod.InstalledVersion}"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Row="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldReleaseDate}"/>
                      <TextBlock Classes="field-value" Text="{Binding SelectedMod.ReleasePublishedAt}"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Row="2" Grid.Column="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldLastInstall}"/>
                      <TextBlock Classes="field-value" Text="{Binding SelectedMod.InstalledAt}"/>
                    </StackPanel>
                  </Border>

                  <Border Grid.Row="4" Grid.ColumnSpan="3" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldGameFolder}"/>
                      <TextBlock Classes="code-copy" Text="{Binding GameFolderPathDisplay}"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <Border Classes="sub-panel" Padding="18">
                  <StackPanel Spacing="14">
                    <TextBlock Classes="panel-title" Text="{Binding Loc.FilesTitle}"/>

                    <StackPanel Spacing="8">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldReleaseFile}"/>
                      <TextBlock Classes="field-value" Text="{Binding SelectedMod.AssetName}"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                      <TextBlock Classes="field-label" Text="{Binding Loc.FieldSelectReleaseFile}"/>
                      <ComboBox Classes="panel-input"
                                ItemsSource="{Binding SelectedMod.AvailableAssets}"
                                SelectedItem="{Binding SelectedMod.SelectedAsset, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,14,*">
                      <StackPanel Spacing="8">
                        <TextBlock Classes="field-label" Text="{Binding Loc.FieldDownloadedFile}"/>
                        <TextBlock Classes="code-copy" Text="{Binding SelectedMod.DownloadedFile}"/>
                      </StackPanel>

                      <StackPanel Grid.Column="2" Spacing="8">
                        <TextBlock Classes="field-label" Text="{Binding Loc.FieldSearchAsset}"/>
                        <TextBox Classes="panel-input"
                                 Text="{Binding SelectedMod.PreferredAssetName, Mode=TwoWay}"
                                 Watermark="{Binding Loc.FieldSearchAssetWatermark}"/>
                      </StackPanel>
                    </Grid>
                  </StackPanel>
                </Border>

                <Border Classes="sub-panel" Padding="18">
                  <StackPanel Spacing="12">
                    <TextBlock Classes="panel-title" Text="{Binding Loc.ChangelogTitle}"/>
                    <TextBox Classes="readonly-panel"
                             Text="{Binding SelectedMod.Changelog}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             Height="320"
                             TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>

        </Grid>

        <Border Grid.Row="4"
                Classes="sub-panel"
                Padding="16,12"
                Margin="0,0,0,6">
          <TextBlock Text="{Binding Loc.FooterTagline}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="13"
                     FontWeight="SemiBold"/>
        </Border>
      </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
  </Border>
</Window>
